# 관리자 API 비밀번호 (admin.html 로그인과 동일하게 맞추세요)
ADMIN_PASSWORD=1111

# 카카오 OAuth (REST API 키 = client_id)
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_REDIRECT_URI=https://dopamine-map.onrender.com/auth/kakao/callback

# 배포 URL (OAuth 콜백 후 리다이렉트용)
APP_BASE_URL=https://dopamine-map.onrender.com

# JWT 서명 키 (운영 환경에서는 반드시 랜덤 문자열로 변경)
JWT_SECRET=change-this-to-a-long-random-secret
