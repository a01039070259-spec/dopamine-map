# 로컬 개발용 — run.bat 실행 시 .env.example 복사되면 이 파일을 .env로 복사 후 키 입력
ADMIN_PASSWORD=1111
KAKAO_REST_API_KEY=your_kakao_rest_api_key
# 카카오 콘솔 [카카오 로그인 > 동의항목]에서 닉네임 활성화 후 true
KAKAO_NICKNAME_SCOPE=false
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://127.0.0.1:8080/auth/kakao/callback
APP_BASE_URL=http://127.0.0.1:8080
JWT_SECRET=local-dev-secret
